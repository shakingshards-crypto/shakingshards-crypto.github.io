---
import { getCollection } from 'astro:content';
import { SITE_TITLE, SITE_DESCRIPTION, SITE_COVER } from '@/consts';
import { getWordCount } from '@/utils/readingTime';

const allBlogPosts = await getCollection('blog');
const sorted = allBlogPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const latestPosts = sorted.slice(0, 5);

const categorySet = new Set<string>();
const tagSet = new Set<string>();
for (const post of allBlogPosts) {
  if (post.data.category) categorySet.add(post.data.category.split('/')[0]);
  for (const tag of post.data.tags || []) tagSet.add(tag);
}

function formatDate(d: Date) {
  return d.toISOString().split('T')[0];
}
---

<section class="relative overflow-hidden" data-hero>
  <div class="absolute inset-0" data-hero-parallax>
    <img
      src={SITE_COVER}
      alt=""
      class="w-full h-full object-cover scale-110"
      aria-hidden="true"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/50 via-black/30 to-black/60"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-black/20 to-transparent"></div>
  </div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-20 sm:py-24 lg:py-32">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div class="text-white">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-white/10 backdrop-blur-sm rounded-full text-xs text-white/70 mb-6 hero-reveal" data-hero-reveal>
          <span class="w-1.5 h-1.5 bg-green-400 rounded-full animate-pulse"></span>
          Disponible para proyectos freelance y encargos
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold mb-5 tracking-tight leading-[1.1] hero-reveal" data-hero-reveal>
          Hola, soy <span class="text-primary font-extrabold bg-clip-text text-transparent bg-gradient-to-r from-primary to-rose-400">ak3k</span>
        </h1>

        <p class="text-lg sm:text-xl text-white/80 font-light mb-8 leading-relaxed max-w-lg hero-reveal" data-hero-reveal>
          Ofrezco mis servicios profesionales en <strong class="text-white font-medium">diseño gráfico</strong> (banners, headers, posters) y <strong class="text-white font-medium">edición de videos</strong> dinámicos para marcas y creadores de contenido.
        </p>

        <div class="grid grid-cols-2 gap-4 mb-8 max-w-md hero-reveal" data-hero-reveal>
          <div class="p-3 bg-white/5 rounded-xl border border-white/10 backdrop-blur-sm hover:bg-white/10 transition-colors">
            <span class="text-[10px] text-primary font-semibold tracking-wider uppercase block mb-1">Diseño Gráfico</span>
            <span class="text-xs text-white/80">Banners, Headers, Posters</span>
          </div>
          <div class="p-3 bg-white/5 rounded-xl border border-white/10 backdrop-blur-sm hover:bg-white/10 transition-colors">
            <span class="text-[10px] text-primary font-semibold tracking-wider uppercase block mb-1">Edición Visual</span>
            <span class="text-xs text-white/80">Cortes, Efectos, Videos Dinámicos</span>
          </div>
        </div>

        <div class="flex items-center gap-3 hero-reveal" data-hero-reveal>
          <a href="/archives" class="inline-flex items-center gap-2 px-6 py-3 bg-primary hover:bg-primary-dark rounded-full text-sm font-medium transition-all shadow-lg shadow-primary/25 hover:scale-[1.03] active:scale-[0.98]">
            Ver portafolio
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a href="/about" class="inline-flex items-center gap-2 px-6 py-3 bg-white/10 hover:bg-white/15 backdrop-blur-sm rounded-full text-sm font-medium text-white/80 hover:text-white transition-all border border-white/10 hover:scale-[1.03] active:scale-[0.98]">
            Saber más
          </a>
        </div>
      </div>

      <div class="hero-reveal" data-hero-reveal>
        <div class="bg-white/[0.07] backdrop-blur-xl rounded-3xl p-6 border border-white/[0.08] shadow-2xl">
          <div class="flex items-center justify-between mb-5">
            <h2 class="text-sm font-semibold text-white/50 flex items-center gap-2">
              <span class="w-1 h-4 bg-primary rounded-full inline-block"></span>
              Trabajos recientes
            </h2>
            <a href="/archives" class="text-xs text-white/30 hover:text-primary transition-colors">
              Ver todos →
            </a>
          </div>
          <div class="space-y-1">
            {latestPosts.map((post, index) => (
              <a
                href={`/post/${post.id}`}
                class="flex items-center gap-4 py-3.5 border-b border-white/[0.05] last:border-0 group hover:bg-white/[0.04] rounded-xl px-3 -mx-3 transition-all"
              >
                <span class="text-[10px] font-mono text-white/20 w-5 shrink-0 tracking-wider">
                  {String(index + 1).padStart(2, '0')}
                </span>
                <div class="flex-1 min-w-0">
                  <h3 class="text-sm font-medium text-white/85 truncate group-hover:text-primary transition-colors">
                    {post.data.title}
                  </h3>
                  <div class="flex items-center gap-2 mt-1 text-[11px] text-white/30">
                    <time datetime={formatDate(post.data.date)}>{formatDate(post.data.date)}</time>
                    {post.data.category && (
                      <>
                        <span class="opacity-40">·</span>
                        <span>{post.data.category}</span>
                      </>
                    )}
                  </div>
                </div>
                <svg class="w-3.5 h-3.5 text-white/15 group-hover:text-primary transition-colors shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/20 hero-reveal" data-hero-reveal>
    <span class="text-[10px] tracking-widest uppercase">Desplazar</span>
    <div class="w-px h-8 bg-gradient-to-b from-white/30 to-transparent"></div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  function initHero() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    gsap.registerPlugin(ScrollTrigger);

    const hero = document.querySelector('[data-hero]');
    const parallaxLayer = document.querySelector('[data-hero-parallax]');
    const reveals = document.querySelectorAll('[data-hero-reveal]');

    if (!hero || !parallaxLayer) return;

    gsap.fromTo(parallaxLayer,
      { y: 0 },
      {
        y: 50,
        ease: 'none',
        scrollTrigger: {
          trigger: hero,
          start: 'top top',
          end: 'bottom top',
          scrub: true,
        },
      }
    );

    if (reveals.length > 0) {
      gsap.fromTo(reveals,
        { opacity: 0, y: 25 },
        {
          opacity: 1,
          y: 0,
          duration: 0.7,
          stagger: 0.1,
          ease: 'power3.out',
          delay: 0.15,
        }
      );
    }
  }

  initHero();
  document.addEventListener('astro:after-swap', () => {
    setTimeout(initHero, 100);
  });
</script>
