---

<button
  id="lang-toggle"
  class="p-2 rounded-lg text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors text-sm font-medium"
  aria-label="Switch Language"
>
  <span class="lang-zh hidden">中</span>
  <span class="lang-en">EN</span>
</button>

<script is:inline>
  (function() {
    function init() {
      var btn = document.getElementById('lang-toggle');
      if (!btn) return;

      function updateLabel() {
        var locale = localStorage.getItem('locale') || 'en';
        var zhLabel = btn.querySelector('.lang-zh');
        var enLabel = btn.querySelector('.lang-en');
        if (locale === 'en') {
          zhLabel?.classList.add('hidden');
          enLabel?.classList.remove('hidden');
        } else {
          zhLabel?.classList.remove('hidden');
          enLabel?.classList.add('hidden');
        }
      }

      btn.addEventListener('click', function() {
        var current = localStorage.getItem('locale') || 'en';
        var next = current === 'en' ? 'zh' : 'en';
        localStorage.setItem('locale', next);
        updateLabel();
        window.location.reload();
      });

      updateLabel();
    }

    init();
    document.addEventListener('astro:after-swap', init);
  })();
</script>
